{
  "server": {
    "host": "0.0.0.0",
    "port": 8001
  },
  "frontend": {
    "port": 3000
  },
  "memory": {
    "command": "your-memory-command",
    "max_lines": 200
  },
  "knowledge": {
    "enabled": true,
    "command": "your-knowledge-command",
    "errors_max_items": 10,
    "errors_max_chars": 2000,
    "project_max_items": 15,
    "project_max_chars": 2000,
    "hotfiles_max_items": 20,
    "hotfiles_recent_days": 7,
    "default_task_count": 5
  },
  "wiki_search": {
    "command": "cco",
    "timeout": 30,
    "max_pages": 5
  },
  "wiki_ingest": {
    "command": "your-ingest-command",
    "retry_commands": ["fallback-command-1", "fallback-command-2"],
    "wiki_base": "/path/to/wiki",
    "timeout": 300,
    "max_message_chars": 50000,
    "schedule": {
      "enabled": true,
      "hour": 0,
      "minute": 0
    },
    "feishu_notify": {
      "enabled": false,
      "cli_path": "",
      "chat_id": "",
      "env_file": ""
    }
  },
  "agents": [
    {
      "name": "my-agent",
      "command": "your-agent-command",
      "cwd": "/path/to/your/project"
    }
  ]
}
